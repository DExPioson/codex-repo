# CloudSpace adapter auth - Production Environment
# Set these as environment variables in your deployment target

# Express adapter
PORT=5000
NC_BASE_URL=https://drive.icingtree.com
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_DB_PATH=./sessions.db
SESSION_COOKIE_SECURE=true
SESSION_TTL_SECONDS=43200
ALLOW_MOCK_SERVICES=false
NEXTCLOUD_BOOTSTRAP_STRATEGY=exchange-or-direct
NEXTCLOUD_APP_PASSWORD_LABEL=CloudSpace Adapter

# Frontend
VITE_PORT=5173
VITE_API_PROXY_TARGET=https://drive.icingtree.com
VITE_NEXTCLOUD_PROXY_TARGET=https://drive.icingtree.com
