# nextcloud-backend/.env.example
# Copy to .env and fill in values before running docker compose up

# Database
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_PASSWORD=change_me_nextcloud

# Nextcloud admin (first-run only - changing these after init has no effect)
NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=change_me_admin

# Frontend URL (injected into headless theme base.php at runtime)
FRONTEND_URL=http://localhost:3000
