# Nextcloud Headless - Local Development Environment
# Copy to .env.development and fill in values

# Nextcloud backend URL (local Docker stack via Nginx proxy)
VITE_NEXTCLOUD_URL=http://localhost:8090

# OAuth2 app credentials (get client_id from Nextcloud Admin -> Security -> OAuth2)
# Register redirect URI as: http://localhost:3000/auth/callback
VITE_OAUTH_CLIENT_ID=your_dev_client_id_here
VITE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# DO NOT add VITE_OAUTH_CLIENT_SECRET - PKCE is used instead (no secret needed)
