# Nextcloud Headless - Production Environment
# Set these as environment variables in your hosting platform (Vercel, Netlify, etc.)
# DO NOT commit a filled-in copy of this file to git

# Nextcloud backend URL (your live Nextcloud instance)
VITE_NEXTCLOUD_URL=https://your-nextcloud-domain.com

# OAuth2 app credentials
# Register redirect URI as: https://drive.icingtree.com/auth/callback
VITE_OAUTH_CLIENT_ID=your_prod_client_id_here
VITE_OAUTH_REDIRECT_URI=https://drive.icingtree.com/auth/callback

# DO NOT add VITE_OAUTH_CLIENT_SECRET - PKCE is used instead (no secret needed)
